{
  "model": "gemini-2.5-pro",
  "temperature": 1,
  "output_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Video",
    "description": "Defines the structure for a video, including its aspect ratio and an array of timed scene metadata.",
    "type": "object",
    "properties": {
      "video_aspect_ratio": {
        "type": "string",
        "description": "Specifies the aspect ratio of the video, either 'landscape' or 'portrait'.",
        "enum": [
          "landscape",
          "portrait"
        ]
      },
      "scenes": {
        "type": "array",
        "description": "An array of scene objects, each representing a distinct segment of the video.",
        "items": {
          "type": "object",
          "properties": {
            "videoDescription": {
              "type": "string",
              "description": "A textual description of the video scene, summarizing what is visually happening."
            },
            "audioTranscriptPortion": {
              "type": "string",
              "description": "The portion of the script corresponding to this scene."
            }
          },
          "required": [
            "videoDescription",
            "audioTranscriptPortion"
          ]
        }
      }
    },
    "required": [
      "video_aspect_ratio",
      "scenes"
    ]
  },
  "thinkingConfig": {
    "thinkingBudget": 32768
  },
  "variables": {
    "tools": ""
  },
  "max_tokens": 65536,
  "prompts": {
    "artstyle": [
      {
        "prompt": "Course-Creation/Video/Designer/Examples/portrait-infographicshow-artstyle",
        "video_style": "infographicshow"
      },
      {
        "prompt": "Course-Creation/Video/Designer/Examples/portrait-4g5g-artstyle",
        "video_style": "4g5g"
      },
      {
        "prompt": "Course-Creation/Video/Designer/Examples/portrait-what-if-artstyle",
        "video_style": "what-if"
      },
      {
        "prompt": "Course-Creation/Video/Designer/Examples/minimal-blue",
        "video_style": "minimal-blue"
      },
      {
        "prompt": "Course-Creation/Video/Designer/Examples/vox-artstyle",
        "video_style": "vox"
      },
      {
        "prompt": "Course-Creation/Video/Designer/Examples/typography-apple",
        "video_style": "typography-apple"
      }
    ]
  }
}
