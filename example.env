# Claude Code OAuth tokens used by the agents spawned from the pipeline.
# BASIC = direction/audio/asset agents; CODE = code-agent (same value is fine,
# or use separate tokens for different rate limits).
BASIC_CLAUDE_CODE_TOKEN="sk-ant-oat01-..."
CODE_CLAUDE_CODE_TOKEN="sk-ant-oat01-..."
# Used by the video-tools short_agent helper when it picks assets.
CLAUDE_CODE_OAUTH_TOKEN="sk-ant-oat01-..."

# ElevenLabs — required for audio TTS and sound effects.
ELEVENLABS_API_KEY="sk_..."
# Pronunciation dictionary id (optional — leave blank if unused).
ELEVEN_LABS_DICTIONARY=""
# Override the primary TTS model (optional).
ELEVENLABS_PRIMARY_MODEL=eleven_flash_v2_5

# Logo.dev — optional, used by the company-logos asset provider as a
# secondary source after iconify's simple-icons. If unset, Logo.dev is skipped.
LOGO_DEV_PUBLISHABLE_KEY=
LOGO_DEV_SECRET_KEY=

# Add ElevenLabs v3 emotion tags to the script before TTS. "false" means the
# audio-agent is skipped and TTS runs on the raw script.
ADD_EMOTIONS=false

# Logging verbosity. "dev" enables DEBUG-level logging; anything else is INFO/WARNING.
ENV=dev

# Mapbox tokens used by any scene that renders a map. Comma-separated; one is
# picked at random per composition. Leave blank if you don't use maps.
MAPBOX_TOKENS=
