# ============================================================
# Claude Code OAuth token (required for agent sub-processes)
# ------------------------------------------------------------
# Token format: sk-ant-oat01-...
# How to get it:
#   1. Install Claude Code CLI: https://docs.claude.com/en/docs/claude-code/overview
#   2. Run `claude setup-token` in your terminal — it opens a browser,
#      completes OAuth, and prints the token once.
#   3. Requires a Claude Pro or Max subscription: https://www.anthropic.com/pricing
# ============================================================
BASIC_CLAUDE_CODE_TOKEN="sk-ant-oat01-..."


# ============================================================
# ElevenLabs (TTS narration + sound effects)
# ------------------------------------------------------------
# API key:            https://elevenlabs.io/app/settings/api-keys
# Voice library:      https://elevenlabs.io/app/voice-library
# Models reference:   https://elevenlabs.io/docs/models
# Pronunciation dict: https://elevenlabs.io/app/pronunciation-dictionaries
# ============================================================
ELEVENLABS_API_KEY="sk_..."

# Primary / fallback voice IDs — copy from the voice library URL or the
# "Copy Voice ID" button on each voice card.
ELEVENLABS_PRIMARY_VOICE_ID=mI8xLTBNjMXAf31I4xlB
ELEVENLABS_FALLBACK_VOICE_ID=yl2ZDV1MzN4HbQJbMihG

# Primary / fallback model IDs (see models reference above).
ELEVENLABS_PRIMARY_MODEL=eleven_v3
ELEVENLABS_FALLBACK_MODEL=eleven_multilingual_v2

# Optional: separate voice used only when narration is rendered at fast speed.
ELEVENLABS_FAST_SPEED_VOICE_ID=

# Speech tuning (safe defaults).
ELEVENLABS_SPEED=1.1
ELEVENLABS_FAST_SPEED=1.5
ELEVENLABS_STABILITY=1.0
ELEVENLABS_SIMILARITY=0.65

# Optional: pronunciation dictionary ID (from the pronunciation-dictionaries
# page above). Leave blank to skip.
ELEVEN_LABS_DICTIONARY=


# ============================================================
# Logo.dev (company logo lookup for scenes that show brand logos)
# ------------------------------------------------------------
# Used by the asset agent to fetch official company logos (e.g. Apple,
# Google, Netflix) when a scene's required_assets include an
# `asset-type: "company-logo"` entry. Iconify simple-icons is tried
# first; Logo.dev is the fallback that covers brands simple-icons
# doesn't have.
#
# How to get the keys:
#   1. Sign up at https://www.logo.dev/
#   2. Open the dashboard: https://www.logo.dev/dashboard/api-keys
#   3. Create a project and copy both keys it generates:
#        - Publishable key  -> LOGO_DEV_PUBLISHABLE_KEY
#        - Secret key       -> LOGO_DEV_SECRET_KEY
#
# Both keys are required for the Logo.dev fallback to work:
#   - SECRET key authenticates the Brand Search API call that resolves
#     a company name to a domain (Bearer token). Without it, the agent
#     logs a warning and skips Logo.dev entirely.
#   - PUBLISHABLE key authorizes the logo-image download URL returned
#     by that search.
#
# Leave both blank if you don't need company logos — scenes without
# `company-logo` assets will still render fine.
# ============================================================
LOGO_DEV_PUBLISHABLE_KEY=
LOGO_DEV_SECRET_KEY=


# ============================================================
# Mapbox (used only when a scene renders a map)
# ------------------------------------------------------------
# Create a public token:  https://account.mapbox.com/access-tokens/
# Docs:                   https://docs.mapbox.com/help/getting-started/access-tokens/
# Comma-separated if you want to rotate across multiple tokens.
# ============================================================
MAPBOX_TOKENS=


# ============================================================
# Runtime environment
# ------------------------------------------------------------
# `dev` enables console logging, `prod` only logs to file.
# ============================================================
ENV=dev
